# Flask
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production

# Database (PostgreSQL 15+)
DATABASE_URL=postgresql://postgres:deno0707@localhost:5432/hrms_kenya

# Redis (optional, for sessions and Celery)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Mail (for password reset, notifications)
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@yourcompany.com

# File uploads (optional override)
# UPLOAD_FOLDER=/var/hrms/uploads

# Logging
LOG_LEVEL=INFO
LOG_TO_STDOUT=false
LOG_DIR=logs

# Test database (for pytest)
# TEST_DATABASE_URL=postgresql://user:password@localhost:5432/hrms_kenya_test
